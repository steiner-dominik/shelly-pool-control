# shelly-pool-control configuration — copy to `.env` and edit.
# NEVER commit a filled-in .env anywhere public.

# --- Shelly device (control authority) ---------------------------------------
# IP or hostname of the Shelly 2PM/1PM Gen2+ running the pool-control script.
POOL_SHELLY_HOST=192.168.1.50
# Admin password if device authentication is enabled (recommended!).
POOL_SHELLY_PASSWORD=
# Seconds between status polls.
POOL_POLL_SECONDS=5

# --- Demo / development ------------------------------------------------------
# 1 = built-in simulator instead of real hardware (great for a first look).
POOL_SIMULATE=0

# --- Web panel / security ----------------------------------------------------
# Comma-separated IPs/CIDRs of your reverse proxy; X-Forwarded-* headers are
# only trusted from these addresses.
POOL_TRUSTED_PROXIES=
# Session lifetime in seconds (default 14 days).
POOL_SESSION_TTL=1209600
# auto = Secure cookies when the request came via https (recommended).
POOL_SECURE_COOKIES=auto

# --- Optional: InfluxDB v2 mirror (SQLite stays authoritative) ---------------
POOL_INFLUX_URL=
POOL_INFLUX_TOKEN=
POOL_INFLUX_ORG=
POOL_INFLUX_BUCKET=

# --- Optional: MQTT bridge with Home Assistant Discovery ---------------------
POOL_MQTT_HOST=
POOL_MQTT_PORT=1883
POOL_MQTT_USER=
POOL_MQTT_PASSWORD=
POOL_MQTT_TLS=0
POOL_MQTT_PREFIX=pool_heating

# --- Misc --------------------------------------------------------------------
POOL_LOG_LEVEL=INFO
